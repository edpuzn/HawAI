# Minimal Dify env (adjust for production)
PORT=5001
CONSOLE_WEB_URL=http://localhost:3000
DATABASE_URL=postgresql://dify:dify@dify-db:5432/dify
REDIS_URL=redis://dify-redis:6379/0
OPENDAL_SCHEME=fs
OPENDAL_FS_ROOT=/app/storage
POSTGRES_HOST=dify-db
POSTGRES_PORT=5432
POSTGRES_USER=dify
POSTGRES_PASSWORD=dify
POSTGRES_DB=dify
SQLALCHEMY_DATABASE_URI=postgresql://dify:dify@dify-db:5432/dify
DB_USERNAME=dify
DB_PASSWORD=dify
DB_HOST=dify-db
DB_PORT=5432
DB_DATABASE=dify
