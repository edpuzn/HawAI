# UI ↔ API adresleri (lokal)
CONSOLE_URL=http://localhost:3000
API_URL=http://localhost:5001

# DB / Redis (compose servis adları)
DB_HOST=dify-db
REDIS_HOST=dify-redis

# Vektör & depolama (ek servis kurmadan basit mod)
VECTOR_STORE=pgvector
STORAGE_TYPE=local

# 🔌 Plugin’ler
ENABLE_PLUGINS=true
PLUGIN_DAEMON_HOST=dify-plugin-daemon
PLUGIN_DAEMON_PORT=5097

# NOT: Bu dosyaya bulut/üretim ayarı ekleme; sadece lokal.
